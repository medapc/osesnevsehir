---
import BaseLayout from "../layouts/BaseLayout.astro";
import { adsKeywords } from "../data/adsKeywords.js";

const TEL = "03842152502";
const TEL_DISPLAY = "0384 215 2502";
const WA_BASE = "https://wa.me/903842152502";
const WA_GENEL = `${WA_BASE}?text=${encodeURIComponent("Merhaba, osesnevsehir.com üzerinden kampanyalar hakkında bilgi almak istiyorum.")}`;

const campaigns = adsKeywords.map((item) => ({
  ...item,
  href: `/kampanya/${item.slug}`,
}));
---

<BaseLayout
  title="Kampanyalar | Oses Çiğ Köfte Nevşehir"
  description="Oses Çiğ Köfte Nevşehir kampanya ve Google Ads hedef sayfaları. Yemek sipariş, dürüm sipariş, öğrenci kampanyası ve çiğ köfte sipariş bağlantıları."
  canonical="https://osesnevsehir.com/kampanyalar"
>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="logo" aria-label="Oses Çiğ Köfte Ana Sayfa">
        <img class="site-logo-image" src="/images/oses-logo.jpg" alt="Oses Çiğ Köfte Nevşehir" />
      </a>
      <details class="mobile-menu">
        <summary aria-label="Menüyü aç">
          <span></span>
          <span></span>
          <span></span>
        </summary>
        <nav aria-label="Mobil menü">
          <a href="/">Anasayfa</a>
          <a href="/menu">Menü</a>
          <a href="/kampanyalar">Kampanyalar</a>
          <a href="/iletisim">İletişim</a>
        </nav>
      </details>
      <nav class="header-nav" aria-label="Ana menü">
        <a href="/">Anasayfa</a>
        <a href="/menu">Menü</a>
        <a href="/kampanyalar" aria-current="page">Kampanyalar</a>
        <a href="/iletisim">İletişim</a>
      </nav>
      <div class="header-actions">
        <a href={`tel:${TEL}`} class="btn btn-outline hide-mobile" data-gads-conversion="phone">☎ {TEL_DISPLAY}</a>
        <a href={WA_GENEL} target="_blank" rel="noopener" class="btn btn-wa">WhatsApp</a>
      </div>
    </div>
  </header>

  <main>
    <section class="campaigns-hero">
      <div class="container campaigns-hero-inner">
        <p class="campaigns-eyebrow">Google Ads Kampanya URL'leri</p>
        <h1>Oses Çiğ Köfte Kampanyaları</h1>
        <p>
          Reklam anahtar kelimelerine özel hazırlanmış hedef sayfalar. Her bağlantı, ilgili arama niyetine göre ayrı başlık ve açıklama ile yayınlanır.
        </p>
      </div>
    </section>

    <section class="campaigns-section">
      <div class="container campaigns-grid">
        {campaigns.map((campaign) => (
          <article class="campaign-card">
            <span class="campaign-tag">/{campaign.slug}</span>
            <h2>{campaign.title}</h2>
            <p>{campaign.description}</p>
            <a href={campaign.href} class="btn btn-primary">Sayfayı Aç</a>
          </article>
        ))}
      </div>
    </section>
  </main>

  <footer class="campaigns-footer" id="iletisim">
    <div class="container campaigns-footer-inner">
      <div>
        <img class="footer-logo-image" src="/images/oses-logo.jpg" alt="Oses Çiğ Köfte" />
        <p>2000 Evler Mah. Şht. Musa Taşdemir Sk. No:13, 50100 Merkez/Nevşehir</p>
      </div>
      <div class="campaigns-footer-actions">
        <a href={`tel:${TEL}`} class="btn btn-outline" data-gads-conversion="phone">☎ {TEL_DISPLAY}</a>
        <a href={WA_GENEL} target="_blank" rel="noopener" class="btn btn-wa">WhatsApp</a>
      </div>
      <nav class="footer-pages" aria-label="Footer sayfaları">
        <a href="/">Anasayfa</a>
        <a href="/menu">Menü</a>
        <a href="/kampanyalar">Kampanyalar</a>
        <a href="/iletisim">İletişim</a>
        <a href="/hakkimizda">Hakkımızda & Sertifikalar</a>
      </nav>
    </div>
  </footer>
</BaseLayout>

<style>
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: #8ec63f;
  border-bottom: 1px solid rgba(142,198,63,.32);
  box-shadow: var(--shadow-sm);
  padding-block: .35rem;
}
.header-inner { display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap; }
.logo { display: flex; align-items: center; flex-shrink: 0; }
.site-logo-image { width: 208px; height: 84px; object-fit: contain; border-radius: 8px; }
.header-nav {
  display: flex;
  align-items: center;
  gap: .25rem;
  margin-left: auto;
  background: rgba(255,255,255,.92);
  border: 1px solid rgba(255,255,255,.7);
  border-radius: 999px;
  padding: .25rem;
}
.header-nav a { padding: .68rem 1rem; border-radius: 999px; font-size: .94rem; font-weight: 800; color: var(--col-text-muted); }
.header-nav a[aria-current="page"],
.header-nav a:hover { background: var(--col-primary); color: #fff; }
.mobile-menu { display: none; }
.header-actions { display: flex; gap: .6rem; align-items: center; flex-shrink: 0; }

.campaigns-hero {
  background: linear-gradient(135deg, #fff8f0 0%, #fdebd0 52%, #fff 100%);
  padding-block: 4.5rem 3rem;
  text-align: center;
}
.campaigns-hero-inner { max-width: 780px; }
.campaigns-eyebrow {
  color: var(--col-primary);
  font-size: .78rem;
  font-weight: 900;
  letter-spacing: .18em;
  text-transform: uppercase;
  margin-bottom: .75rem;
}
.campaigns-hero h1 {
  font-size: clamp(2.1rem, 4vw, 3.35rem);
  margin-bottom: .75rem;
}
.campaigns-hero p {
  color: var(--col-text-muted);
  font-size: 1.05rem;
  max-width: 680px;
  margin-inline: auto;
}
.campaigns-section {
  background: #fffaf4;
  padding-block: 2.5rem 4rem;
}
.campaigns-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 1rem;
}
.campaign-card {
  background: #fff;
  border: 1px solid #ecd9c8;
  border-radius: 10px;
  padding: 1.1rem;
  box-shadow: 0 14px 34px rgba(26,18,11,.06);
  display: flex;
  flex-direction: column;
  gap: .75rem;
}
.campaign-tag {
  color: var(--col-primary);
  font-size: .75rem;
  font-weight: 900;
}
.campaign-card h2 {
  font-size: 1.08rem;
  line-height: 1.3;
}
.campaign-card p {
  color: var(--col-text-muted);
  font-size: .88rem;
  flex: 1;
}
.campaigns-footer {
  background: #160b06;
  color: #e8ddd5;
  padding-block: 2rem;
}
.campaigns-footer-inner {
  display: grid;
  grid-template-columns: minmax(0,1fr) auto;
  gap: 1.25rem;
  align-items: center;
}
.footer-logo-image {
  width: 126px;
  height: 48px;
  object-fit: contain;
  border-radius: 8px;
  margin-bottom: .75rem;
  background: #8ec63f;
}
.campaigns-footer p { color: #c7b8ac; font-size: .9rem; }
.campaigns-footer-actions { display: flex; gap: .75rem; flex-wrap: wrap; }
.campaigns-footer .footer-pages { grid-column: 1 / -1; justify-content: flex-start; }

@media (max-width: 768px) {
  .site-header { padding-block: .7rem; }
  .header-inner { flex-wrap: nowrap; justify-content: flex-start; gap: .55rem; }
  .logo { padding: 0; background: transparent; border: 0; box-shadow: none; }
  .site-logo-image { width: 122px; height: 52px; border-radius: 0; }
  .mobile-menu { display: none !important; }
  .header-nav {
    display: flex !important;
    flex: 1;
    min-width: 0;
    margin-left: 0;
    justify-content: flex-end;
    gap: .15rem;
    background: rgba(255,255,255,.82);
    border: 1px solid rgba(255,255,255,.58);
    border-radius: 999px;
    padding: .2rem;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .header-nav::-webkit-scrollbar { display: none; }
  .header-nav a {
    flex: 0 0 auto;
    padding: .46rem .52rem;
    font-size: .72rem;
    font-weight: 800;
    color: var(--col-text);
  }
  .header-actions { display: none !important; }
  .campaigns-footer-inner { grid-template-columns: 1fr; text-align: center; }
  .campaigns-footer-actions,
  .campaigns-footer .footer-pages { justify-content: center; }
}
@media (max-width: 480px) {
  .site-logo-image { width: 108px; height: 46px; }
  .header-nav a { font-size: .72rem; padding: .46rem .5rem; }
}
</style>
